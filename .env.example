# =============================================================================
# 环境变量配置文件
# =============================================================================
# 用途：存储 API 密钥等敏感信息
# 注意：此文件不应提交到 git（已添加到.gitignore）
# =============================================================================

# 阿里云百炼 API Key (Qwen)
# 获取地址：https://bailian.console.aliyun.com/cn-beijing/?tab=doc
ALIYUN_API_KEY=your_aliyun_api_key_here

# 深度求索 API Key (DeepSeek)
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# GitHub Token（用于 GitHub API 访问）
GITHUB_TOKEN=ghp_your_github_personal_access_token

# 高德地图 API Key
# 获取地址：https://console.amap.com/
AMAP_KEY=your_amap_api_key_here

# Milvus 连接地址
# 本地 Docker：http://localhost:19530
# 远程服务器：http://your-server-ip:19530
MILVUS_URI=http://localhost:19530

# Milvus 数据库名（默认为 default）
MILVUS_DB_NAME=default

# 是否使用真实 Embedding（true/false）
USE_REAL_EMBEDDING=false