# =============================================================================
# 环境变量配置文件
# =============================================================================
# 用途：存储 API 密钥等敏感信息
# 注意：此文件不应提交到 git（已添加到.gitignore）
# =============================================================================

# 阿里云百炼 API Key (Qwen)
# 获取地址：https://bailian.console.aliyun.com/cn-beijing/?tab=doc
ALIYUN_API_KEY=your_aliyun_api_key_here

# 深度求索 API Key (DeepSeek)
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
