# =============================================================================
# 环境变量配置示例
# =============================================================================
# 复制此文件为 .env 并填入你的 API Key
# =============================================================================

# 阿里云百炼 API Key (https://bailian.console.aliyun.com/)
ALIYUN_API_KEY=sk-your-aliyun-api-key-here

# DeepSeek API Key (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# OpenAI API Key (可选，https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Ollama 配置 (本地模型，不需要 API Key)
# 确保已安装 Ollama 并下载模型：ollama pull qwen3.5:2b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:2b
