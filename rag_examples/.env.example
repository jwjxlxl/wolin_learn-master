# =============================================================================
# RAG 教学示例 - 环境变量配置
# =============================================================================
# 使用说明：
#   1. 复制此文件为 .env ：cp .env.example .env
#   2. 填写你的 API 密钥
#   3. .env 文件不会被提交到 git（已在 .gitignore 中）
# =============================================================================

# 阿里云百炼 API Key（用于 Embedding 和 Qwen 大模型调用）
# 获取地址：https://bailian.console.aliyun.com/
ALIYUN_API_KEY=your_aliyun_api_key_here

# 阿里云 DashScope API Key（部分示例使用此变量名，与 ALIYUN_API_KEY 相同）
DASHSCOPE_API_KEY=your_aliyun_api_key_here

# Milvus 连接地址
# 本地 Docker：http://localhost:19530
# 远程服务器：http://your-server-ip:19530
MILVUS_URI=http://localhost:19530

# Milvus 数据库名（默认为 default）
MILVUS_DB_NAME=default
